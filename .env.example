# Supabase (public — ok in client bundle)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Supabase (server-only — NEVER use NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Custom Access Token Hook (set to match hook secret in Supabase dashboard)
CUSTOM_ACCESS_TOKEN_SECRET=v1,whsec_YOUR_HOOK_SECRET

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
